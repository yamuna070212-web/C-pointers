#include <stdio.h>

int sum(int *arr, int n);

int main()
{
    int arr[5] = {1,2,3,4,5};

    printf("Sum = %d", sum(arr, 5));

    return 0;
}

int sum(int *arr, int n)
{
    int i, total = 0;

    for(i = 0; i < n; i++)
    {
        total += *(arr + i);
    }

    return total;
}
Sample Output
Sum = 15
