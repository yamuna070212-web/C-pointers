#include <stdio.h>

int main()
{
    char str1[100], str2[100];
    char *p1, *p2;

    printf("Enter First String: ");
    scanf("%s", str1);

    printf("Enter Second String: ");
    scanf("%s", str2);

    p1 = str1;
    p2 = str2;

    while(*p1 == *p2 && *p1 != '\0')
    {
        p1++;
        p2++;
    }

    if(*p1 == *p2)
        printf("Strings are Equal");
    else
        printf("Strings are Not Equal");

    return 0;
}
