#include <stdio.h>

void swap(int *a, int *b);

int main()
{
    int x = 10, y = 20;

    printf("Before Swap: %d %d\n", x, y);

    swap(&x, &y);

    printf("After Swap: %d %d", x, y);

    return 0;
}

void swap(int *a, int *b)
{
    int temp;

    temp = *a;
    *a = *b;
    *b = temp;
}
Sample Output
Before Swap: 10 20
After Swap: 20 10
