#include <stdio.h>

int main()
{
    char str[100];
    char *ptr;
    int length = 0;

    printf("Enter String: ");
    scanf("%s", str);

    ptr = str;

    while(*ptr != '\0')
    {
        length++;
        ptr++;
    }

    printf("Length = %d", length);

    return 0;
}
