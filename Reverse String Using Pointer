#include <stdio.h>
#include <string.h>

int main()
{
    char str[100];
    char *start, *end, temp;

    printf("Enter String: ");
    scanf("%s", str);

    start = str;
    end = str + strlen(str) - 1;

    while(start < end)
    {
        temp = *start;
        *start = *end;
        *end = temp;

        start++;
        end--;
    }

    printf("Reversed String: %s", str);

    return 0;
}
Sample Output
Enter String: Welcome

